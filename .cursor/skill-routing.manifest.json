  "taskRoutes": [
    {
      "id": "task-new-feature",
      "patterns": ["新功能", "实现", "开发", "implement", "build feature"],
      "skills": ["ion-skill-autopilot"],
      "steps": ["read SESSION_STATE.md", "run skill-route", "run dev-preflight"]
    },
    {
      "id": "task-ui-page",
      "patterns": ["页面", "dashboard", "swap", "staking", "ui", "frontend"],
      "routeId": "frontend-ui"
    },
    {
      "id": "task-contract",
      "patterns": ["合约", "func", "solidity", "amm", "vault"],
      "routeId": "contracts-func"
    },
    {
      "id": "task-github-discovery",
      "patterns": ["github", "高星", "trending", "开源项目", "daily discovery"],
      "skills": ["ion-github-daily-discovery"],
      "steps": [
        "node scripts/github-daily-pipeline.mjs",
        "read ion-private-core/.memory-bank/github-daily/latest.md",
        "node scripts/skill-route.mjs --task"
      ]
    }
  ]
}
