    "@tanstack/react-query": "^5.100.11",
    "@ton/core": "^0.63.1",
    "@tonconnect/sdk": "^4.0.0",
    "buffer": "^6.0.3",
    "framer-motion": "latest",
    "lightweight-charts": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "viem": "^2.52.2",
    "wagmi": "^3.6.21"
  },
  "overrides": {
    "ws": "8.21.0"
  },
