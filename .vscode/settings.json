{
  // === Cursor Agent Auto-Accept (no manual confirmation) ===
  "cursor.composer.yoloMode": true,
  "cursor.composer.autoRun": true,
  "cursor.terminal.executeAllCommandsWithoutPrompt": true,
  "cursor.autoAcceptFiles": true,
  "cursor.chat.autoApplyDiffs": true,
  "cursor.composer.shouldAutoAcceptDiffs": true,
  "cursor.agent.autoRunCommands": true,
  "cursor.general.enableYoloMode": true,
  // === On-Save Pipeline ===
  "emeraldwalk.runonsave": {
    "showElapsed": true,
    "message": "[ION DEX] on-save pipeline (quick encoding + compile-func)",
    "commands": [
      {
        "match": ".*",
        "notMatch": "node_modules|[\\/](?:\\.git|dist|build|out|coverage)(?:[\\/]|$)",
        "isAsync": false,
        "autoShowOutputPanel": "error",
        "cmd": "node \"${workspaceFolder}/scripts/ion-on-save-pipeline.mjs\" \"${file}\""
      }
    ]
  }
}
