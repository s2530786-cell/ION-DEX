    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "latest",
    "cross-env": "^10.1.0",
    "postcss": "latest",
    "start-server-and-test": "^2.1.2",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "^8.0.16"
