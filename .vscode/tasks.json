{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile FunC on Startup",
      "type": "shell",
      "command": "node scripts/compile-func.mjs 2>&1 | Set-Content scripts/compile-errors.txt",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "ION DEX: compile-func.mjs",
      "type": "shell",
      "command": "node scripts\\compile-func.mjs",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "group": "build"
    },
    {
      "label": "ION DEX: Task2 Func compile then agent-verify",
      "type": "shell",
      "command": "cmd /d /c echo ION^ DEX Task2 chain: compile-func + agent-verify finished.",
      "dependsOn": [
        "ION DEX: compile-func.mjs",
        "ION DEX: agent-verify (noninteractive)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "ION DEX: agent-verify (noninteractive)",
      "type": "shell",
      "command": "scripts\\agent-verify.cmd",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "ION DEX: verify-full-save-log --no-pause",
      "type": "shell",
      "command": "scripts\\verify-full-save-log.cmd --no-pause",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": "test"
    },
    {
      "label": "ION DEX: verify-100.ps1",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\verify-100.ps1",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": "test"
    }
  ]
}
