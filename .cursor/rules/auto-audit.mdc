// ═══════════════════════════════════════════
// ION DEX — Auto Audit Pipeline Rule
// Trigger: after every .sol / .fc / .ts / .tsx file change
// ═══════════════════════════════════════════

// 🔨 Solidity Audit (after .sol changes)
rule "Solidity Audit: Compile + Lint + Slither"
when:
  files: ["contracts/bsc/src/**/*.sol", "contracts/bsc/test/**/*.sol"]
then:
  step 1: run "D:\\openclaw-tools\\foundry\\bin\\forge.exe build" in "contracts/bsc/"
  step 2: if forge-build failed → STOP → fix errors → back to step 1
  step 3: run "solhint contracts/bsc/src/**/*.sol"
  step 4: run "D:\\openclaw-tools\\venv\\Scripts\\slither.exe . --solc D:\\openclaw-tools\\foundry\\bin\\forge.exe" in "contracts/bsc/"
  step 5: run "D:\\openclaw-tools\\foundry\\bin\\forge.exe test" in "contracts/bsc/"
  step 6: if ANY step failed → audit log in `reports/audit-errors.md` → fix → restart
  step 7: all green → commit

// ⚡ FunC Audit (after .fc changes)
rule "FunC Audit: Compile"
when:
  files: ["contracts/ion/**/*.fc"]
then:
  step 1: run "node scripts/compile-func.mjs"
  step 2: if failed → STOP → fix → back to step 1
  step 3: all green → commit

// 🎨 Frontend Audit (after .tsx/.ts changes)
rule "Frontend Audit: TypeCheck + Build"
when:
  files: ["frontend/src/**/*.tsx", "frontend/src/**/*.ts"]
then:
  step 1: run "npx tsc --noEmit" in "frontend/"
  step 2: run "npx vite build" in "frontend/"
  step 3: if failed → STOP → fix garbage code (motionmotiondiv, missing props, bad imports)
  step 4: all green → commit

// ⚙️ Backend Audit (after .ts changes)
rule "Backend Audit: TypeCheck"
when:
  files: ["backend/src/**/*.ts"]
then:
  step 1: run "npx tsc --noEmit" in "backend/"
  step 2: if failed → STOP → fix → back to step 1
  step 3: all green → commit

// 🛡️ Full Audit (on demand or before major commits)
rule "Full Security Audit"
when:
  manual: true  // run with: node scripts/audit-all.mjs
then:
  step 1: forge build
  step 2: forge test (all 16 test categories)
  step 3: solhint (all .sol files)
  step 4: slither (static analysis)
  step 5: compile-func (all .fc files)
  step 6: tsc --noEmit (frontend + backend)
  step 7: vite build (frontend)
  step 8: report at reports/audit-errors.md

// ⏱️ Before Commit Checklist
rule "Pre-Commit Gate"
when:
  before_commit: true
then:
  check 1: forge build → GREEN
  check 2: forge test → ALL GREEN (16/16)
  check 3: no "motionmotion", "bianjibianji", "asdf" in any file
  check 4: no "TODO" in .sol or .fc files
  check 5: no "props: any" in .tsx files
  check 6: no unused imports
  ALL PASS → commit with "type: description" format
  ANY FAIL → fix → recheck

// 📊 Auto-Report
rule "After Commit: Update Progress"
then:
  run: "node scripts/report-progress.mjs"
  update: docs/99-current-progress.md
  push: origin 2026-05-19-q7fx
