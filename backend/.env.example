# ION DEX backend — copy to .env and fill secrets (never commit .env)

# live | auto | test-mock (NODE_ENV=test defaults to test-mock)
ION_DATA_MODE=auto

# BSC JSON-RPC (public seed; use your own node in production)
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_CHAIN_ID=56

# Official BSC ION ERC-20 (default in code if unset)
# BSC_ION_TOKEN_ADDRESS=0xe1ab61f7b093435204df32f5b3a405de55445ea8
# BSC burn sink (dead) — see docs/ion-official-canonical-addresses.md
# BSC_ION_BURN_ADDRESS=0x000000000000000000000000000000000000dead

# CoinMarketCap Pro API — required for live market tickers
# CMC_API_KEY=

# Optional CMC base URL override
# CMC_API_BASE_URL=https://pro-api.coinmarketcap.com

# ION mainnet HTTP API (reachability probe for /api/config/public)
ION_API_BASE_URL=https://api.mainnet.ice.io/http/v2/

# Outbound HTTP timeout (ms)
ION_HTTP_TIMEOUT_MS=12000
