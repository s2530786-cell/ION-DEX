;; ── Message Mode Flags ───────────────────────────────────────────

const CARRY_ALL_BALANCE = 128;
const QCARRY_ALL_BALANCE = 128;   ;; alias for quiet mode
const DESTROY_IF_ZERO = 32;

;; ── Context Globals ──────────────────────────────────────────────
;; Stored as typed globals because FunC ctx.at() cannot return both
;; int and slice from the same function.

global slice ctx::body_slice;       ;; BODY  - message body as slice
global slice ctx::raw_body_slice;   ;; RAW BODY - original body including opcode
global slice ctx::sender_slice;     ;; SENDER - sender address
global int ctx::opcode_val;         ;; OPCODE - 32-bit operation code
global int ctx::is_bounced;         ;; IS_BOUNCED - bounce flag
global int ctx::balance_val;        ;; BALANCE - contract balance
global int ctx::fwd_fee_val;        ;; FWD_FEE - forward fee
global int ctx::msg_value_val;      ;; message value

;; Context field index constants (for compatibility with ctx.at convention)
const BODY = 1;
const SENDER = 2;
const OPCODE = 3;
const IS_BOUNCED = 4;
const BALANCE = 5;
const FWD_FEE = 6;

() ctx::init(int my_balance, int msg_value, cell in_msg_full, slice in_msg_body) impure inline {
    ;; Store raw slices/values into typed globals
    ctx::msg_value_val = msg_value;
    ctx::balance_val = my_balance;
    ctx::raw_body_slice = in_msg_body;
    if in_msg_body.slice_bits() >= 32 {
        ctx::opcode_val = in_msg_body.preload_uint(32);
        ctx::body_slice = in_msg_body.skip_bits(32);
    } else {
        ctx::opcode_val = 0;
        ctx::body_slice = in_msg_body;
    }

    ;; Extract sender address
    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);
    ctx::is_bounced = flags & 1;
    ctx::sender_slice = cs~load_msg_addr();

    ;; Parse remaining header fields for fwd_fee
    cs~load_msg_addr();             ;; dst
    cs~load_coins();                ;; value
    cs~load_uint(1);                ;; extracurrency flag
    cs~load_coins();                ;; ihr_fee
    ctx::fwd_fee_val = cs~load_coins();  ;; fwd_fee
}

;; ── Typed context accessors (use these instead of ctx.at) ────────

slice ctx::body() inline { return ctx::body_slice; }
slice ctx::raw_body() inline { return ctx::raw_body_slice; }
slice ctx::sender() inline { return ctx::sender_slice; }
int   ctx::opcode() inline { return ctx::opcode_val; }
int   ctx::isBounced() inline { return ctx::is_bounced; }
int   ctx::balance() inline { return ctx::balance_val; }
int   ctx::fwdFee() inline { return ctx::fwd_fee_val; }
int   ctx::value() inline { return ctx::msg_value_val; }

;; ── Address Utilities ────────────────────────────────────────────

int address::check_workchain(slice addr, int expected_workchain) inline {
    (int wc, int _hash) = parse_std_addr(addr);
    return wc == expected_workchain ? -1 : 0;
}

int address::is_none(slice addr) inline {
    return addr.preload_uint(2) == 0;
}

slice address::none() inline {
    return begin_cell().store_uint(0, 2).end_cell().begin_parse();
}

;; ── Reserve Utilities ────────────────────────────────────────────

() reserves::max_balance(int amount) impure inline {
    raw_reserve(amount, 2);  ;; reserve_exactly mode
}

;; ── ION Chain Standard Library Compatibility Shim ──────────────────
;; These functions are provided by full stdlib.fc / @ston-fi/funcbox
;; on TON mainnet, but may not be present in ION chain's stdlib.

int equal_slices(slice a, slice b) inline {
    return equal_slice_bits(a, b);
}

;; Simple integer sqrt via Newton's method
int sqrt(int x) inline {
    if x <= 0 { return 0; }
    int z = x;
    int i = 0;
    while i < 32 {
        i += 1;
        z = (z + x / z) >> 1;
    }
    return z;
}

;; ── Simple Message Sending ───────────────────────────────────────

int math::mul_div(int a, int b, int denom) inline {
    throw_unless(error::invalid_amount, denom > 0);
    return muldiv(a, b, denom);
}

int amm::get_amount_out(int amount_in, int reserve_in, int reserve_out, int fee_num, int fee_denom) inline {
    throw_unless(error::invalid_amount, amount_in > 0);
    throw_unless(error::insufficient_liquidity, (reserve_in > 0) & (reserve_out > 0));
    int amount_in_with_fee = math::mul_div(amount_in, fee_num, fee_denom);
    int numerator = amount_in_with_fee * reserve_out;
    int denominator = reserve_in + amount_in_with_fee;
    throw_unless(error::zero_output, denominator > 0);
    return numerator / denominator;
}

() msgs::send_internal(int value, slice to, cell body, int bounce, int mode) impure inline {
    builder msg = begin_cell()
        .store_uint(bounce ? 0x18 : 0x10, 6)
        .store_slice(to)
        .store_coins(value)
        .store_uint(0, 1 + 4 + 4 + 64 + 32)
        .store_uint(0, 1);  ;; no StateInit

    if cell_null?(body) {
        msg~store_uint(0, 1);  ;; empty body, inline
    } else {
        msg~store_uint(1, 1);  ;; body as ref
        msg = msg.store_ref(body);
    }

    send_raw_message(msg.end_cell(), mode);
}

() msgs::send_simple(int value, slice to, cell body, int mode) impure inline {
    msgs::send_internal(value, to, body, -1, mode);
}

() msgs::send_value(int value, slice to, cell body, int mode) impure inline {
    msgs::send_internal(value, to, body, -1, mode);
}

() msgs::send_nobounce(int value, slice to, cell body, int mode) impure inline {
    msgs::send_internal(value, to, body, 0, mode);
}
