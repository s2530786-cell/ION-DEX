{
  "$schema": "./skill-routing.schema.json",
  "version": 1,
  "description": "ION DEX Cursor Skill autopilot — path and keyword routing. Private skills resolve under .cursor/skills-private/ first.",
  "baseSkills": [
    "chinese-language",
    "ion-dex-memory",
    "cursor-engineering-workflow",
    "ion-dev-accelerators"
  ],
  "privateSkillRoot": ".cursor/skills-private",
  "publicSkillRoot": ".cursor/skills",
  "pathRoutes": [
    {
      "id": "engineering-standards",
      "priority": 100,
      "paths": ["docs/00-engineering-standards.md", "AGENTS.md", "SESSION_STATE.md"],
      "skills": [],
      "docs": ["docs/00-engineering-standards.md"],
      "memoryBank": [],
      "preflight": true
    },
    {
      "id": "frontend-ui",
      "priority": 90,
      "paths": ["frontend/src/**", "frontend/e2e/**", "frontend/playwright.config.ts", "frontend/tailwind.config.*", "frontend/index.html"],
      "skills": ["ion-web3-ui"],
      "docs": ["docs/05-product-prd.md", "docs/06-page-flow-and-user-journeys.md", "docs/10-ui-design-route.md"],
      "memoryBank": [".memory-bank/overall-design-framework.md", ".memory-bank/implementation-playbook.md"],
      "preflight": true,
      "verify": ["node scripts/dev-preflight.mjs", "cd frontend && npm run verify"]
    },
    {
      "id": "backend-data",
      "priority": 90,
      "paths": ["backend/src/**", "backend/test/**"],
      "skills": ["ion-data-backend"],
      "docs": ["docs/00-engineering-standards.md"],
      "memoryBank": [".memory-bank/live-data-reference.md", ".memory-bank/architecture-audit.md"],
      "preflight": true,
      "verify": ["cd backend && npm run build && npm run test"]
    },
    {
      "id": "contracts-func",
      "priority": 95,
      "paths": ["contracts/ion/**", "contracts/**/*.fc", "contracts/**/*.func"],
      "skills": ["ion-contract-audit", "ion-official-source"],
      "docs": ["docs/23-security-audit-and-stress-sandbox.md"],
      "memoryBank": [".memory-bank/security-audit-and-stress-framework.md", ".memory-bank/ion-dex-nuke/official-source-index.md"],
      "preflight": true,
      "securityPreflight": true
    },
    {
      "id": "contracts-solidity",
      "priority": 95,
      "paths": ["contracts/**/*.sol", "contracts/script/**"],
      "skills": ["ion-contract-audit"],
      "memoryBank": [".memory-bank/security-audit-and-stress-framework.md"],
      "securityPreflight": true
    },
    {
      "id": "verification-scripts",
      "priority": 80,
      "paths": ["scripts/**", ".github/**"],
      "skills": ["cursor-engineering-workflow", "ion-autonomous-work-resume"],
      "verify": ["scripts\\verify-full-save-log.cmd --no-pause"]
    },
    {
      "id": "autonomous-work-queue",
      "priority": 85,
      "paths": [
        ".memory-bank/autonomous-work-queue.json",
        ".memory-bank/autonomous-work-watchdog-state.json",
        "scripts/autonomous-work-watchdog.mjs",
        "scripts/run-autonomous-work-watchdog.cmd"
      ],
      "skills": ["ion-autonomous-work-resume", "ion-dex-memory"],
      "preflight": false
    },
    {
      "id": "memory-bank",
      "priority": 70,
      "paths": [".memory-bank/**"],
      "skills": ["ion-dex-memory", "self-evolving"],
      "preflight": false
    },
    {
      "id": "cursor-skills-public",
      "priority": 60,
      "paths": [".cursor/skills/**"],
      "skills": ["find-skill", "skill-vetter"],
      "preflight": false
    },
    {
      "id": "cursor-skills-private",
      "priority": 60,
      "paths": [".cursor/skills-private/**"],
      "skills": ["find-skill", "skill-vetter"],
      "privateOnly": true,
      "preflight": false
    },
    {
      "id": "docs-product",
      "priority": 50,
      "paths": ["docs/**"],
      "skills": ["ion-dex-memory", "summarize-pro"],
      "preflight": true
    },
    {
      "id": "github-daily",
      "priority": 55,
      "paths": [
        "scripts/github-daily-discovery.mjs",
        "scripts/github-daily-pipeline.mjs",
        "scripts/github-daily-install.mjs",
        "scripts/github-daily-skill-stubs.mjs",
        "scripts/github-daily-queries.json",
        "scripts/github-daily.cmd",
        "scripts/register-github-daily-task.ps1",
        ".memory-bank/github-daily/**",
        "docs/github-daily-discovery.md"
      ],
      "skills": ["ion-github-daily-discovery", "skill-vetter", "find-skill"],
      "memoryBank": ["ion-private-core/.memory-bank/github-daily/README.md"],
      "preflight": false
    },
    {
      "id": "github-discovered-stubs",
      "priority": 56,
      "paths": [".cursor/skills/github-discovered/**"],
      "skills": ["ion-github-daily-discovery", "skill-vetter"],
      "preflight": false
    },
    {
      "id": "media-motion-skills",
      "priority": 58,
      "paths": [
        ".cursor/skills/hyperframes/**",
        ".cursor/skills/hyperframes-*/**",
        ".cursor/skills/gsap/**",
        ".cursor/skills/three/**",
        ".cursor/skills/typegpu/**",
        ".cursor/skills/lottie/**",
        ".cursor/skills/remotion-to-hyperframes/**",
        ".cursor/skills/website-to-hyperframes/**"
      ],
      "skills": ["hyperframes", "hyperframes-cli", "gsap", "three", "typegpu"],
      "privateSkills": ["hyperframes", "money-printer-turbo"],
      "preflight": false
    }
  ],
