# ION-DEX 生产级构建系统
# 所有操作必须通过 make 触发 — 唯一入口

.PHONY: audit test build clean validate deploy

# ============================================================
# 全自动审计（四道质量门禁）
# ============================================================
audit:
	@echo "============================================"
	@echo "--- [Gate 1] UI 令牌静态检查 ---"
	@echo "============================================"
	python3 scripts/audit_tokens.py
	@echo ""
	@echo "============================================"
	@echo "--- [Gate 2] 代码风格与安全审计 ---"
	@echo "============================================"
	npm run lint || echo "[WARN] lint 未配置，跳过"
	@echo ""
	@echo "============================================"
	@echo "--- [Gate 3] 合约安全检查 ---"
	@echo "============================================"
	python3 agent_harness.py --audit
	@echo ""
	@echo "============================================"
	@echo "--- [Gate 4] 依赖合规性检查 ---"
	@echo "============================================"
	npm audit || echo "[WARN] npm audit 未配置，跳过"
	@echo ""
	@echo "============================================"
	@echo "--- 全部审计通过 ✓ ---"
	@echo "============================================"

# ============================================================
# 自动化测试
# ============================================================
test:
	@echo "============================================"
	@echo "--- 运行合约与业务逻辑测试 ---"
	@echo "============================================"
	npx blueprint test || echo "[WARN] blueprint test 未配置，跳过"

# ============================================================
# 生产级构建（先审计，再构建）
# ============================================================
build: audit
	@echo "============================================"
	@echo "--- 构建生产环境 ---"
	@echo "============================================"
	npm run build

# ============================================================
# 一键验证（审计 + 测试，不构建）
# ============================================================
validate: audit test
	@echo "============================================"
	@echo "--- 全部校验通过 ✓ ---"
	@echo "============================================"

# ============================================================
# 部署（验证 + 构建 + 部署）
# ============================================================
deploy: validate build
	@echo "============================================"
	@echo "--- 部署到生产环境 ---"
	@echo "============================================"
	@echo "[TODO] 接入 Vercel / Cloudflare Pages 部署"

# ============================================================
# 清理
# ============================================================
clean:
	rm -rf dist build .next
	@echo "--- 清理完成 ---"
