{
  "mcpServers": {
    "desktop-commander": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@wonderwhy-er/desktop-commander@0.2.41"
      ]
    },
    "ion-dex-memory-bank": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@allpepper/memory-bank-mcp@0.2.2"
      ],
      "env": {
        "MEMORY_BANK_ROOT": "${workspaceFolder}/.memory-bank"
      }
    }
  }
}
