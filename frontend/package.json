{
  "name": "ion-dex-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --host=127.0.0.1 --port=3010 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "preview:local": "vite preview --host=127.0.0.1 --port=4173",
    "preview:test": "vite preview --host=127.0.0.1 --strictPort",
    "test:e2e": "playwright test",
    "verify:e2e": "playwright test",
    "verify": "VITE_ION_API_BASE_URL=http://127.0.0.1:8787 npm run build && node scripts/verify-e2e.mjs",
    "capture-ui": "node scripts/capture-ui-screenshots.mjs",
    "audit:high": "node scripts/audit-high.mjs"
  },
  "dependencies": {
    "@ion-gateway/sdk": "^3.1.1-beta.0",
    "@ion-gateway/ui": "^2.1.1-beta.0",
    "@ion-gateway/ui-react": "^2.1.1-beta.0",
    "@tanstack/react-query": "^5.100.11",
    "@ton/core": "^0.63.1",
    "@tonconnect/sdk": "^3.4.1",
    "buffer": "^6.0.3",
    "framer-motion": "latest",
    "lightweight-charts": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwindcss": "^3.4.19",
    "viem": "^2.50.4",
    "wagmi": "^3.6.15"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "start-server-and-test": "^2.1.2",
    "typescript": "latest",
    "vite": "latest"
  }
