# ION DEX frontend — copy to .env.local or .env (never commit secrets)

# Dev (`npm run dev`): leave API base unset — requests use /api and Vite proxies to 8787.
# Only set an absolute URL when the UI and API are on different origins by design.
# VITE_ION_API_RELATIVE=1
# VITE_ION_API_BASE_URL=http://127.0.0.1:8787

VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org/

# TODO: deploy burn contract on mainnet
VITE_BURN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Optional burn indexer base URL (empty until service exists)
VITE_BURN_INDEXER_URL=

# TODO: deploy vault lock contract on mainnet
VITE_VAULT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Deploy-only local secret — do not commit real keys
# VITE_VAULT_DEPLOYER_KEY=
