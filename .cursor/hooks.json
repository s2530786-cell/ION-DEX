{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "node scripts/ion-on-save-pipeline.mjs --cursor-hook",
        "timeout": 540,
        "failClosed": false
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "node scripts/ion-on-save-pipeline.mjs --cursor-hook",
        "timeout": 540,
        "failClosed": false
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/ion-verify-on-stop.cmd",
        "timeout": 900,
        "failClosed": false
      }
    ]
  }
}
